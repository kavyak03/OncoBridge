# Example configuration for REAL infrastructure runs.
# - For a credential-free run, use: --demo-mode (no config required)
# - For a local mock setup, use config.mock.yaml

sql:
  # MariaDB example:
  # sqlalchemy_url: "mysql+pymysql://USER:PASSWORD@HOST:3306/DB"
  sqlalchemy_url: "mysql+pymysql://user:pass@host:3306/ehr"
  tables:
    clinical_metadata: "clinical_metadata"
    therapies: "therapy_lines"

tiledb:
  variants_uri: "/path/to/tiledb/variants_array"
  expression_uri: "/path/to/tiledb/expression_array"
  config: {}

provenance:
  log_dir: "run_logs"
